import random
import json
import tkinter as tk
from tkinter import messagebox, simpledialog

# Предопределённые задачи
tasks = [
    {"task": "Прочитать статью", "type": "учёба"},
    {"task": "Сделать зарядку", "type": "спорт"},
    {"task": "Написать отчёт", "type": "работа"},
    {"task": "Посмотреть обучающее видео", "type": "учёба"},
    {"task": "Пробежка на свежем воздухе", "type": "спорт"},
    {"task": "Подготовить презентацию", "type": "работа"}
]
# Функция для генерации случайной задачи
def generate_task():
    selected_task = random.choice(tasks)
    task_label.config(text=selected_task["task"])
    history.append(selected_task)
    update_history()

# Функция для обновления истории задач
def update_history():
    history_list.delete(0, tk.END)
    for task in history:
        history_list.insert(tk.END, f"{task['task']} ({task['type']})")

# Инициализация основного окна
root = tk.Tk()
root.title("Random Task Generator")

# Элементы интерфейса
task_label = tk.Label(root, text="Нажмите 'Сгенерировать задачу'", font=("Arial", 14))
task_label.pack(pady=20)

generate_button = tk.Button(root, text="Сгенерировать задачу", command=generate_task)
generate_button.pack(pady=10)

history = []
history_list = tk.Listbox(root, width=50)
history_list.pack(pady=20)

root.mainloop()
def filter_tasks(task_type):
    filtered_tasks = [task for task in history if task['type'] == task_type]
    history_list.delete(0, tk.END)
    for task in filtered_tasks:
        history_list.insert(tk.END, f"{task['task']} ({task['type']})")

filter_label = tk.Label(root, text="Фильтр по типу задачи:")
filter_label.pack()

filter_var = tk.StringVar(value="все")
filter_menu = tk.OptionMenu(root, filter_var, "все", "учёба", "спорт", "работа", command=lambda x: filter_tasks(filter_var.get()))
filter_menu.pack()
def save_history():
    with open('history.json', 'w', encoding='utf-8') as f:
        json.dump(history, f, ensure_ascii=False, indent=4)

def load_history():
    try:
        with open('history.json', 'r', encoding='utf-8') as f:
            return json.load(f)
    except FileNotFoundError:
        return []

history = load_history()
update_history()
def add_task():
    new_task = simpledialog.askstring("Добавить задачу", "Введите новую задачу:")
    if new_task and new_task.strip():
        tasks.append({"task": new_task.strip(), "type": "другое"})
        messagebox.showinfo("Успех", "Задача добавлена!")
    else:
        messagebox.showerror("Ошибка", "Задача не может быть пустой!")

add_button = tk.Button(root, text="Добавить задачу", command=add_task)
add_button.pack(pady=10)
